# Environment Variables Template
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://ofhklmyaioxznrqiolad.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cloudflare Turnstile (captcha)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# CORS Configuration
CLIENT_URL=https://zelia.io

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=your_publishable_key_here
STRIPE_SECRET_KEY=your_secret_key_here
STRIPE_PRICE_AMOUNT=2499
STRIPE_PRICE_CURRENCY=eur
STRIPE_PRODUCT_NAME="Zélia+ — Accès complet"

# Stripe — formation payante pour les parents (landing /parents), compte Stripe distinct
STRIPE_PARENT_SECRET_KEY=your_parent_training_secret_key_here
STRIPE_PARENT_PUBLISHABLE_KEY=your_parent_training_publishable_key_here
STRIPE_PARENT_PRICE_AMOUNT=9900
STRIPE_PARENT_PRICE_CURRENCY=eur
STRIPE_PARENT_PRODUCT_NAME="Formation Zélia — Devenez le meilleur allié orientation de votre enfant"
STRIPE_PARENT_WEBHOOK_SECRET=your_parent_training_webhook_secret_here
